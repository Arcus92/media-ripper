<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MediaRipper.App"
             xmlns:local="clr-namespace:MediaRipper"
             xmlns:utils="clr-namespace:MediaRipper.Utils"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
             
     <Application.Resources>
         <ResourceDictionary>
             <ResourceDictionary.MergedDictionaries>
                 <MergeResourceInclude Source="Resources/Layouts.axaml" />
                 <MergeResourceInclude Source="Resources/Colors.axaml" />
                 
                 <MergeResourceInclude Source="Resources/Strings/Languages.axaml" />
                 
                 <!-- Default language -->
                 <MergeResourceInclude Source="Resources/Strings/English.axaml" />
             </ResourceDictionary.MergedDictionaries>
         </ResourceDictionary>
         
         <!-- Converters -->
         <utils:DynamicResourceKeyConverter x:Key="DynamicResourceKeyConverter"/>
     </Application.Resources>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="Resources/Styles.axaml" />
    </Application.Styles>
</Application>